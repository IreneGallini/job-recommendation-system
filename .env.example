# Gmail address that sends (and receives) the notification emails
EMAIL_ADDRESS=you@gmail.com

# Gmail App Password (not your account password)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on your Google account
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# URL of the SimplifyJobs internship README to watch.
# Update this when the Summer2027 repo is created (usually July/August of the prior year).
# Current default targets Summer2026; swap to Summer2027-Internships when available.
SIMPLIFY_README_URL=https://raw.githubusercontent.com/SimplifyJobs/Summer2026-Internships/dev/README.md
